<div class="game-page">
  <h1>Dot Dash</h1>
  <p class="instructions">Click the moving dot as many times as you can in 20 seconds.</p>

  <div class="hud">
    <span>Time: <strong id="time-left">20</strong>s</span>
    <span>Score: <strong id="score">0</strong></span>
  </div>

  <div id="arena" class="arena" aria-label="Game arena">
    <button id="dot" class="dot" aria-label="Click target"></button>
  </div>

  <div class="controls">
    <button id="start-game" class="control-button">Start game</button>
    <p id="status" class="status">Press start when you're ready.</p>
  </div>
</div>
